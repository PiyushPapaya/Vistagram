# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drop-in media (your own predownloaded files — keep folder structure + docs, ignore the media)
/public/media/posts/*
/public/media/reels/*
!/public/media/posts/.gitkeep
!/public/media/reels/.gitkeep
!/public/media/README.md

# Auto-generated copies from videos_phots/ (regenerated by scripts/generate-media.mjs
# on predev/prebuild). The source files in /videos_phots and src/lib/generated-media.ts
# are committed; these large copies are not.
/public/media/feed/*
!/public/media/feed/.gitkeep
